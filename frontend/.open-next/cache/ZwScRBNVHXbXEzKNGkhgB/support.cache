package w-5 h-5 text-white\" aria-hidden=\"true\"><path d=\"M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z\"></path><path d=\"M12 22V12\"></path><polyline points=\"3.29 7 12 12 20.71 7\"></polyline><path d=\"m7.5 4.27 9 5.15\"></path></svg></div><div><div class=\"font-display text-lg font-bold uppercase tracking-[0.2em] text-slate-900\">Midwest</div><div class=\"text-[0.65rem] font-semibold uppercase tracking-[0.35em] text-brand-500\">Shipment Company</div></div></a><div class=\"hidden flex-1 items-center justify-center md:flex\"><nav class=\"flex flex-wrap items-center justify-center gap-6\"><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/\">Home</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/services\">Services</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/about\">About</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/contact\">Contact</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/track\">Track Parcel</a></nav></div><div class=\"hidden items-center gap-3 md:flex\"><a class=\"rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-slate-900 transition hover:border-brand-400 hover:bg-slate-50\" href=\"/track\">Track Package</a><a class=\"rounded-full bg-brand-500 px-5 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-white transition hover:bg-brand-400\" href=\"/contact\">Get Quote</a></div><button type=\"button\" class=\"inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 p-3 text-white transition hover:bg-white/10 md:hidden\" aria-label=\"Toggle navigation menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu h-5 w-5\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></header><main><section class=\"relative overflow-hidden pt-32 pb-20 px-4 sm:px-6 lg:px-8\"><div class=\"mx-auto max-w-7xl text-center\"><h1 class=\"text-5xl sm:text-6xl font-bold mb-6\">Support Center</h1><p class=\"text-xl text-slate-300 max-w-3xl mx-auto\">Need help with a shipment, quote, or logistics question? Our support team is ready to assist 24/7.</p></div></section><section class=\"px-4 sm:px-6 lg:px-8 pb-24\"><div class=\"mx-auto max-w-7xl grid gap-12 lg:grid-cols-[1.2fr_0.8fr]\"><div class=\"space-y-10\"><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl shadow-xl\"><p class=\"text-brand-400 uppercase tracking-widest text-sm mb-3\">Quick support</p><h2 class=\"text-3xl font-bold mb-4\">Need help fast?</h2><p class=\"text-slate-300 leading-7 mb-6\">Use the support assistant to get immediate guidance on tracking, quotes, urgent shipments, or documentation.</p><div class=\"grid gap-4 sm:grid-cols-2\"><a class=\"rounded-3xl border border-white/10 bg-slate-950/80 p-6 transition hover:border-brand-400/30 hover:bg-slate-950\" href=\"/track\"><div class=\"flex items-center gap-3 mb-4\"><div class=\"inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-brand-500/10 text-brand-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-truck h-5 w-5\" aria-hidden=\"true\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"></path><path d=\"M15 18H9\"></path><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"></path><circle cx=\"17\" cy=\"18\" r=\"2\"></circle><circle cx=\"7\" cy=\"18\" r=\"2\"></circle></svg></div><div><h3 class=\"font-semibold\">Track a shipment</h3><p class=\"text-sm text-slate-400\">Check live status, route progress, and delivery updates.</p></div></div><div class=\"inline-flex items-center gap-2 text-sm font-semibold text-brand-400\">Continue <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-4 w-4\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg></div></a><a class=\"rounded-3xl border border-white/10 bg-slate-950/80 p-6 transition hover:border-brand-400/30 hover:bg-slate-950\" href=\"/contact\"><div class=\"flex items-center gap-3 mb-4\"><div class=\"inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-brand-500/10 text-brand-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check h-5 w-5\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div><h3 class=\"font-semibold\">Request a quote</h3><p class=\"text-sm text-slate-400\">Start a conversation for urgent, secure, or high-volume freight needs.</p></div></div><div class=\"inline-flex items-center gap-2 text-sm font-semibold text-brand-400\">Continue <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-4 w-4\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg></div></a><a class=\"rounded-3xl border border-white/10 bg-slate-950/80 p-6 transition hover:border-brand-400/30 hover:bg-slate-950\" href=\"/contact\"><div class=\"flex items-center gap-3 mb-4\"><div class=\"inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-brand-500/10 text-brand-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-headphones h-5 w-5\" aria-hidden=\"true\"><path d=\"M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3\"></path></svg></div><div><h3 class=\"font-semibold\">Contact support</h3><p class=\"text-sm text-slate-400\">Reach our team for documentation, scheduling, and account help.</p></div></div><div class=\"inline-flex items-center gap-2 text-sm font-semibold text-brand-400\">Continue <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-4 w-4\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg></div></a></div></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl shadow-xl\"><p class=\"text-brand-400 uppercase tracking-widest text-sm mb-3\">Support details</p><div class=\"space-y-5\"><div class=\"flex items-start gap-4\"><div class=\"mt-1 rounded-2xl bg-brand-500/10 p-3 text-brand-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail h-5 w-5\" aria-hidden=\"true\"><path d=\"m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7\"></path><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rect></svg></div><div><p class=\"text-sm uppercase tracking-[0.24em] text-slate-400\">Email</p><p class=\"mt-2 text-lg font-semibold text-white\">support@midwestshipment.com</p></div></div><div class=\"flex items-start gap-4\"><div class=\"mt-1 rounded-2xl bg-brand-500/10 p-3 text-brand-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone h-5 w-5\" aria-hidden=\"true\"><path d=\"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384\"></path></svg></div><div><p class=\"text-sm uppercase tracking-[0.24em] text-slate-400\">Phone</p><p class=\"mt-2 text-lg font-semibold text-white\">+1 (614) 555-0123</p></div></div><div class=\"flex items-start gap-4\"><div class=\"mt-1 rounded-2xl bg-brand-500/10 p-3 text-brand-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock3 lucide-clock-3 h-5 w-5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6h4\"></path></svg></div><div><p class=\"text-sm uppercase tracking-[0.24em] text-slate-400\">Hours</p><p class=\"mt-2 text-lg font-semibold text-white\">24/7 Global Support</p></div></div></div></div></div><div class=\"space-y-10\"><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl shadow-xl\"><p class=\"text-brand-400 uppercase tracking-widest text-sm mb-4\">Live assistant</p><div class=\"space-y-4\"><div class=\"rounded-3xl p-5 bg-slate-900 text-slate-100\"><p class=\"text-sm leading-7\">Hi! I am your support assistant. Ask me about tracking, quotes, urgent shipments, or service questions.</p></div></div><div class=\"mt-6\"><textarea rows=\"4\" class=\"w-full rounded-3xl border border-slate-700 bg-slate-950/80 px-4 py-4 text-sm text-white outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-400/20\" placeholder=\"Ask about tracking, rates, or urgent support...\"></textarea><button type=\"button\" class=\"mt-4 inline-flex items-center justify-center rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-500/30 transition hover:bg-brand-400\">Send Message</button></div></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl shadow-xl\"><p class=\"text-brand-400 uppercase tracking-widest text-sm mb-4\">Frequently Asked Questions</p><div class=\"space-y-3\"><button type=\"button\" class=\"w-full rounded-3xl border border-slate-700 bg-slate-950/80 px-5 py-4 text-left\"><div class=\"flex items-center justify-between gap-4\"><span class=\"font-semibold text-white\">How quickly can I get help for an urgent shipment?</span><span class=\"text-brand-400\">-</span></div><p class=\"mt-3 text-sm leading-7 text-slate-300\">Our support team is available 24/7 and can assist with urgent routing, escalation, and delivery coordination immediately.</p></button><button type=\"button\" class=\"w-full rounded-3xl border border-slate-700 bg-slate-950/80 px-5 py-4 text-left\"><div class=\"flex items-center justify-between gap-4\"><span class=\"font-semibold text-white\">Can I track my shipment from the support center?</span><span class=\"text-brand-400\">+</span></div></button><button type=\"button\" class=\"w-full rounded-3xl border border-slate-700 bg-slate-950/80 px-5 py-4 text-left\"><div class=\"flex items-center justify-between gap-4\"><span class=\"font-semibold text-white\">Do you offer support for high-value or secure freight?</span><span class=\"text-brand-400\">+</span></div></button><button type=\"button\" class=\"w-full rounded-3xl border border-slate-700 bg-slate-950/80 px-5 py-4 text-left\"><div class=\"flex items-center justify-between gap-4\"><span class=\"font-semibold text-white\">What hours is customer support available?</span><span class=\"text-brand-400\">+</span></div></button></div></div></div></div></section></main><section class=\"mx-auto max-w-7xl px-4 pb-24 pt-20 sm:px-6 lg:px-8\"><div class=\"mb-12 text-center\"><p class=\"section-subtitle text-brand-400\">Trusted by international partners</p><h2 class=\"text-4xl font-bold tracking-tight text-white sm:text-5xl\">Customer testimonials from premium logistics clients</h2></div><div class=\"swiper space-y-8 overflow-hidden\"><div class=\"swiper-wrapper\"><div class=\"swiper-slide\"><div class=\"rounded-[2rem] border border-white/10 bg-slate-950/85 p-10 shadow-2xl backdrop-blur-xl text-white\"><div class=\"flex items-center gap-2 text-brand-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-star h-4 w-4\" aria-hidden=\"true\"><path d=\"M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-star h-4 w-4\" aria-hidden=\"true\"><path d=\"M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.1