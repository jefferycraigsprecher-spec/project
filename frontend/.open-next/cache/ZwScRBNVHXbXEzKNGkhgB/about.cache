{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"},"segmentPaths":["/_tree","/_full","/about/__PAGE__","/about","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"__variable_7c7c8c __variable_4b3a9b\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/images/services/service1.jpg\"/><link rel=\"preload\" as=\"image\" href=\"https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&amp;fit=crop&amp;w=200&amp;q=80\"/><link rel=\"preload\" as=\"image\" href=\"https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?auto=format&amp;fit=crop&amp;w=200&amp;q=80\"/><link rel=\"preload\" as=\"image\" href=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&amp;fit=crop&amp;w=200&amp;q=80\"/><link rel=\"stylesheet\" href=\"/_next/static/css/2ce740725dd38fb4.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/711872e418c8971c.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-1838f0371a103621.js\"/><script src=\"/_next/static/chunks/4bd1b696-c2f6e0877b6c10aa.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-fe7ea2cd824b63b2.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-83f22664e1a5920b.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-3953cc33eeceb44e.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-c05f7d71bd4f4323.js\" async=\"\"></script><script src=\"/_next/static/chunks/296-bc2bb672a0ed9756.js\" async=\"\"></script><script src=\"/_next/static/chunks/3797-cde00ce595b8de22.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/about/page-71b495fd5cb64c47.js\" async=\"\"></script><title>Midwest Shipment Company | Fast, Reliable Logistics</title><meta name=\"description\" content=\"Midwest Shipment Company – delivering packages across the USA with speed, reliability, and care. Track your shipment in real time.\"/><meta name=\"keywords\" content=\"shipping, logistics, courier, tracking, freight, Columbus Ohio, midwest delivery\"/><meta property=\"og:title\" content=\"Midwest Shipment Company\"/><meta property=\"og:description\" content=\"Fast, reliable logistics across the USA\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Midwest Shipment Company\"/><meta name=\"twitter:description\" content=\"Fast, reliable logistics across the USA\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"font-sans antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"bg-slate-950 text-white font-sans\"><header class=\"sticky top-0 z-50 transition duration-500 bg-white\"><div class=\"border-b border-slate-200 bg-white text-slate-700\"><div class=\"mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-2 text-[0.75rem] uppercase tracking-[0.3em]\"><div class=\"flex flex-wrap items-center gap-4 text-slate-700\"><a href=\"tel:+12397468728\" class=\"inline-flex items-center gap-2 font-semibold text-slate-700 transition hover:text-brand-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone h-3.5 w-3.5 text-brand-500\" aria-hidden=\"true\"><path d=\"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384\"></path></svg> +1 239-746-8728</a><a href=\"mailto:info.midwestshipment@gmail.com\" class=\"inline-flex items-center gap-2 font-semibold text-slate-700 transition hover:text-brand-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail h-3.5 w-3.5 text-brand-300\" aria-hidden=\"true\"><path d=\"m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7\"></path><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rect></svg> info.midwestshipment@gmail.com</a><span class=\"hidden items-center gap-2 text-slate-400 sm:inline-flex\">Office hours: Mon - Fri 8:00 AM - 7:00 PM</span></div><div class=\"flex flex-wrap items-center gap-3 justify-end\"><div class=\"language-switcher shrink-0 relative\"><button type=\"button\" aria-expanded=\"false\" class=\"inline-flex min-w-0 max-w-[12rem] items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 text-[0.75rem] font-bold text-brand-500 shadow-sm transition hover:border-brand-500 hover:text-brand-600\"><span class=\"language-switcher__icon\">🌐</span><span class=\"max-w-full overflow-hidden text-ellipsis whitespace-nowrap\">🇺🇸 English</span><span class=\"text-xs\">▼</span></button><div id=\"google_translate_element\" class=\"hidden\" aria-hidden=\"true\"></div><p class=\"sr-only\">Powered by Google Translate</p></div><div class=\"hidden items-center gap-3 md:flex\"><a class=\"rounded-full bg-brand-500 px-4 py-2 text-xs font-semibold uppercase tracking-[0.25em] text-white transition hover:bg-brand-400\" href=\"/admin/dashboard\">Admin Portal</a></div></div></div></div><div class=\"relative mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 bg-white\"><a class=\"flex items-center gap-3\" href=\"/\"><div class=\"rounded-full bg-brand-500 p-2 shadow-sm shadow-brand-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-package w-5 h-5 text-white\" aria-hidden=\"true\"><path d=\"M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z\"></path><path d=\"M12 22V12\"></path><polyline points=\"3.29 7 12 12 20.71 7\"></polyline><path d=\"m7.5 4.27 9 5.15\"></path></svg></div><div><div class=\"font-display text-lg font-bold uppercase tracking-[0.2em] text-slate-900\">Midwest</div><div class=\"text-[0.65rem] font-semibold uppercase tracking-[0.35em] text-brand-500\">Shipment Company</div></div></a><div class=\"hidden flex-1 items-center justify-center md:flex\"><nav class=\"flex flex-wrap items-center justify-center gap-6\"><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/\">Home</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/services\">Services</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/about\">About</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/contact\">Contact</a><a class=\"text-[0.8rem] font-semibold uppercase tracking-[0.24em] text-slate-700 transition hover:text-brand-500\" href=\"/track\">Track Parcel</a></nav></div><div class=\"hidden items-center gap-3 md:flex\"><a class=\"rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-slate-900 transition hover:border-brand-400 hover:bg-slate-50\" href=\"/track\">Track Package</a><a class=\"rounded-full bg-brand-500 px-5 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-white transition hover:bg-brand-400\" href=\"/contact\">Get Quote</a></div><button type=\"button\" class=\"inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 p-3 text-white transition hover:bg-white/10 md:hidden\" aria-label=\"Toggle navigation menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu h-5 w-5\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></header><main><section class=\"relative overflow-hidden bg-navy-950 text-white\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.18),_transparent_18%),radial-gradient(circle_at_bottom_right,_rgba(59,130,246,0.16),_transparent_28%)]\"></div><div class=\"relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8\"><div class=\"grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center\"><div class=\"space-y-8\"><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 shadow-2xl backdrop-blur-xl\"><p class=\"text-sm uppercase tracking-[0.35em] text-sky-300\">Midwest Shipment</p><h1 class=\"mt-4 text-4xl font-bold tracking-tight sm:text-5xl\">Built on trusted logistics and premium customer care.</h1><p class=\"mt-6 max-w-2xl text-slate-200 leading-8\">For 15 years, we’ve guided brands and businesses through secure international freight, local delivery, and strategic supply chain solutions.</p><div class=\"mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap\"><a class=\"inline-flex items-center justify-center rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-400\" href=\"/about\">Meet the Team</a><a class=\"inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/20\" href=\"/contact\">Contact Sales</a></div></div><div class=\"grid gap-4 sm:grid-cols-3\"><div class=\"rounded-[1.75rem] border border-white/10 bg-white/5 p-5\"><p class=\"text-xs uppercase tracking-[0.35em] text-slate-300\">Next-day delivery</p><p class=\"mt-3 text-2xl font-bold text-white\">1-2 days</p></div><div class=\"rounded-[1.75rem] border border-white/10 bg-white/5 p-5\"><p class=\"text-xs uppercase tracking-[0.35em] text-slate-300\">Covered routes</p><p class=\"mt-3 text-2xl font-bold text-white\">160+ countries</p></div><div class=\"rounded-[1.75rem] border border-white/10 bg-white/5 p-5\"><p class=\"text-xs uppercase tracking-[0.35em] text-slate-300\">Support</p><p class=\"mt-3 text-2xl font-bold text-white\">24/7 logistics care</p></div></div><div class=\"flex flex-wrap items-center gap-3\"><button type=\"button\" class=\"rounded-full px-4 py-2 text-sm font-semibold transition bg-sky-500 text-white\">Built on trusted logistics and premium customer care.</button><button type=\"button\" class=\"rounded-full px-4 py-2 text-sm font-semibold transition bg-white/10 text-slate-200 hover:bg-white/20\">Our mission is to make complex shipping effortless.</button></div></div><div class=\"relative overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900 shadow-2xl\"><img src=\"/images/services/service1.jpg\" alt=\"Built on trusted logistics and premium customer care.\" class=\"h-full w-full object-cover\"/><div class=\"absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/95 to-transparent p-6\"><p class=\"text-sm uppercase tracking-[0.35em] text-sky-300\">Featured route</p><p class=\"mt-2 text-xl font-semibold text-white\">Reliable pickup and delivery for every lane.</p></div></div></div></div></section><section class=\"px-4 sm:px-6 lg:px-8 pb-24\"><div class=\"mx-auto max-w-7xl\"><div class=\"grid md:grid-cols-2 gap-12\"><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-10 backdrop-blur-xl\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award h-12 w-12 text-brand-400 mb-6\" aria-hidden=\"true\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"></path><circle cx=\"12\" cy=\"8\" r=\"6\"></circle></svg><h2 class=\"text-3xl font-bold mb-4\">Our Mission</h2><p class=\"text-slate-300 leading-8\">To deliver world-class logistics services that empower businesses and individuals to move goods reliably, transparently, and affordably across the globe. We&#x27;re committed to providing exceptional care for every shipment.</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-10 backdrop-blur-xl\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe h-12 w-12 text-brand-400 mb-6\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg><h2 class=\"text-3xl font-bold mb-4\">Our Vision</h2><p class=\"text-slate-300 leading-8\">To be the most trusted and innovative courier partner for businesses worldwide, setting industry standards for reliability, speed, and customer satisfaction. Built in Ohio. Built for America. Trusted globally.</p></div></div></div></section><section class=\"bg-slate-900/50 px-4 sm:px-6 lg:px-8 py-24\"><div class=\"mx-auto max-w-7xl\"><div class=\"grid grid-cols-2 md:grid-cols-4 gap-8\"><div class=\"text-center\"><p class=\"text-4xl sm:text-5xl font-bold text-brand-400 mb-3\">15+</p><p class=\"text-slate-300 text-sm uppercase tracking-widest\">Years in Business</p></div><div class=\"text-center\"><p class=\"text-4xl sm:text-5xl font-bold text-brand-400 mb-3\">500+</p><p class=\"text-slate-300 text-sm uppercase tracking-widest\">Global Partners</p></div><div class=\"text-center\"><p class=\"text-4xl sm:text-5xl font-bold text-brand-400 mb-3\">2M+</p><p class=\"text-slate-300 text-sm uppercase tracking-widest\">Shipments Delivered</p></div><div class=\"text-center\"><p class=\"text-4xl sm:text-5xl font-bold text-brand-400 mb-3\">160+</p><p class=\"text-slate-300 text-sm uppercase tracking-widest\">Countries Served</p></div></div></div></section><section class=\"px-4 sm:px-6 lg:px-8 py-24\"><div class=\"mx-auto max-w-7xl\"><div class=\"text-center mb-16\"><p class=\"text-brand-400 font-semibold uppercase tracking-widest mb-3\">Core Values</p><h2 class=\"text-4xl font-bold\">What Drives Us Every Day</h2></div><div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\"><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl hover:bg-white/10 transition\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-8 w-8 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg><h3 class=\"text-xl font-bold mb-3\">Reliability</h3><p class=\"text-slate-300 text-sm leading-7\">Every shipment is treated with utmost care. On-time delivery isn&#x27;t a goal—it&#x27;s a promise.</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl hover:bg-white/10 transition\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-8 w-8 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg><h3 class=\"text-xl font-bold mb-3\">Transparency</h3><p class=\"text-slate-300 text-sm leading-7\">Real-time tracking, clear pricing, and honest communication build trust with every customer.</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl hover:bg-white/10 transition\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-8 w-8 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg><h3 class=\"text-xl font-bold mb-3\">Innovation</h3><p class=\"text-slate-300 text-sm leading-7\">Cutting-edge technology and continuous improvement keep us ahead in the logistics industry.</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl hover:bg-white/10 transition\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-8 w-8 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg><h3 class=\"text-xl font-bold mb-3\">Customer Focus</h3><p class=\"text-slate-300 text-sm leading-7\">24/7 support and personalized solutions ensure your logistics needs are always our priority.</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl hover:bg-white/10 transition\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-8 w-8 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg><h3 class=\"text-xl font-bold mb-3\">Sustainability</h3><p class=\"text-slate-300 text-sm leading-7\">Eco-conscious operations and responsible practices for a better future.</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl hover:bg-white/10 transition\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-8 w-8 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg><h3 class=\"text-xl font-bold mb-3\">Integrity</h3><p class=\"text-slate-300 text-sm leading-7\">Ethical business practices and fair dealings with partners and customers alike.</p></div></div></div></section><section class=\"bg-slate-900/50 px-4 sm:px-6 lg:px-8 py-24\"><div class=\"mx-auto max-w-7xl\"><div class=\"text-center mb-12\"><p class=\"text-brand-400 font-semibold uppercase tracking-widest mb-3\">Our Location</p><h2 class=\"text-4xl font-bold mb-6\">Columbus Headquarters</h2></div><div class=\"grid md:grid-cols-2 gap-8\"><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin h-10 w-10 text-brand-400 mb-4\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><h3 class=\"text-2xl font-bold mb-2\">Address</h3><p class=\"text-slate-300 text-lg\">1450 Industrial Parkway</p><p class=\"text-slate-300 text-lg\">Columbus, Ohio, USA</p></div><div class=\"rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-xl\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock h-10 w-10 text-brand-400 mb-4\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg><h3 class=\"text-2xl font-bold mb-2\">Business Hours</h3><p class=\"text-slate-300\">Monday–Friday: 6:00 AM – 8:00 PM ET</p><p class=\"text-slate-300\">Saturday: 8:00 AM – 4:00 PM ET</p></div></div></div></section><section class=\"px-4 sm:px-6 lg:px-8 py-24\"><div class=\"mx-auto max-w-4xl text-center\"><h2 class=\"text-4xl font-bold mb-6\">Ready to Experience Excellence?</h2><p class=\"text-xl text-slate-300 mb-10\">Join thousands of businesses that trust Midwest Shipment for their logistics needs.</p><div class=\"flex flex-col sm:flex-row gap-4 justify-center\"><a class=\"inline-flex items-center justify-center rounded-full bg-brand-500 px-10 py-4 text-lg font-semibold text-white shadow-lg shadow-brand-500/30 transition hover:bg-brand-400\" href=\"/contact\">Get in Touch</a><a class=\"inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-10 py-4 text-lg font-semibold text-white transition hover:bg-white/20\" href=\"/services\">Explore Services</a></div></div></section><section class=\"mx-auto max-w-7xl px-4 pb-24 pt-20 sm:px-6 lg:px-8\"><div class=\"mb-12 text-center\"><p class=\"section-subtitle text-brand-400\">Trusted by international partners</p><h2 class=\"text-4xl font-bold tracking-tight text-white sm:text-5xl\">Customer testimonials from premium logistics clients</h2></div><div class=\"swiper space-y-8 overflow-hidden\"><div class=\"swiper-wrapper\"><div class=\"swiper-slide\"><div class=\"rounded-[2rem] border border-white/10 bg-slate-950/85 p-10 shadow-2xl backdrop-blur-xl text-white\"><div class=\"flex items-center gap-2 text-brand-300\"><svg xmlns=\"http://www.w3.org/2000/svg\