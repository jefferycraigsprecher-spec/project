{
  "version": 3,
  "services": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/barcodes/(.*)$",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/$1"
    }
  ]
}
